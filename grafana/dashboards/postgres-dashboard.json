      "targets": [
        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  u.usename as db_user,\n  pss.query,\n  pss.calls,\n  ROUND(pss.total_exec_time::numeric, 2) as total_exec_time,\n  ROUND(pss.mean_exec_time::numeric, 4) as mean_exec_time\nFROM pg_stat_statements pss\nJOIN pg_user u ON pss.userid = u.usesysid\nWHERE ('$db_user' = 'All' OR u.usename = '$db_user')\n  AND pss.query !~* 'dblink'\n  AND pss.query !~* 'pg_catalog'\n  AND pss.query !~* 'information_schema'\nORDER BY pss.total_exec_time DESC\nLIMIT 10;",
          "refId": "A"
        }
      ],
